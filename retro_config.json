{
  "audio": {
    "add_bgm_by_default": true,
    "default_bgm_volume": 0.05
  },
  "subtitles": {
    "enabled": true,
    "highlight_spoken_word": true,
    "layout_mode": "kinetic",
    "font_name": "Georgia",
    "font_size_word": 150,
    "font_size_highlight": 72,
    "font_color_primary": "&H0000FFFF",
    "font_color_white": "&H00FFFFFF", 
    "margin_v": 350,
    "alignment": 2
  },
  "video": {
    "default_transition": "none",
    "default_transition_duration": 1,
    "ken_burns_movement": false,
    "use_overlay": false,
    "overlay_opacity": 0.15,
    "effects": {
      "shake_zoom": {
        "enabled": true,
        "shake_intensity": 0.3,
        "zoom_out": 1.1,
        "duration": 0.3
      }
    }
  }
}